# Sao chép thành .env và chỉnh giá trị.

# Backend socket (mặc định: http://localhost:3002)
# VITE_SOCKET_URL=http://localhost:3002

# Link liên hệ hiển thị trong ô chat (Zalo OA / số Zalo, trang Messenger)
# VITE_CONTACT_ZALO_URL=https://zalo.me/your-id
# VITE_CONTACT_MESSENGER_URL=https://m.me/your-page
